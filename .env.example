# ========== Docker / systemd ==========
# Docker Hub image used by deploy/install.sh and docker-compose.yml.
WINDSURFPOOL_IMAGE=luka762/windsurfpool:latest
# Host port mapped to the container PORT.
HOST_PORT=3003

# ========== Server ==========
PORT=3003
# API key for incoming /v1/* requests (leave empty for open access).
# Also acts as the admin fallback only when DASHBOARD_PASSWORD is empty.
API_KEY=
# Required for /dashboard/api/* and /auth/* management routes.
# Prefer setting this to a strong value before exposing the service.
DASHBOARD_PASSWORD=

# ========== Codeium / Windsurf Auth ==========
# Seed the account pool at startup (optional, you can also use /auth/login API).
# Option 1: Direct API key from Windsurf (sk-ws-...)
CODEIUM_API_KEY=
# Option 2: Token from https://windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to the Windsurf language server binary.
# ARM Linux: /opt/windsurf/language_server_linux_arm
# x86_64 Linux: /opt/windsurf/language_server_linux_x64
LS_BINARY_PATH=/opt/windsurf/language_server_linux_arm
# gRPC port for language server
LS_PORT=42100
# Language server runtime data directory inside the container.
LS_DATA_DIR=/app/data

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
# Log level: debug | info | warn | error
LOG_LEVEL=info
LOG_DIR=/app/logs
