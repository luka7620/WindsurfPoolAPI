# Copy this file to .env in the Docker deploy directory.
# Default install location: /opt/windsurfpool/.env
#
# Docker image to pull on service start.
WINDSURFPOOL_IMAGE=luka762/windsurfpool:latest

# Host/container HTTP ports. Keep both the same unless you need remapping.
HOST_PORT=3003
PORT=3003

# Incoming API auth. Leave API_KEY empty only if this is not exposed publicly.
API_KEY=
DASHBOARD_PASSWORD=change-me

# Optional account bootstrap. You can also add accounts from the dashboard.
# Multiple values are comma-separated.
CODEIUM_API_KEY=
CODEIUM_AUTH_TOKEN=

# Windsurf language server mounted from the host at /opt/windsurf.
# On ARM Linux use /opt/windsurf/language_server_linux_arm.
# On x86_64 Linux use /opt/windsurf/language_server_linux_x64.
LS_BINARY_PATH=/opt/windsurf/language_server_linux_arm
LS_PORT=42100
LS_DATA_DIR=/app/data

# Runtime defaults.
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info
LOG_DIR=/app/logs

# Optional advanced tuning.
CASCADE_MAX_HISTORY_BYTES=200000
